<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CatWar: My Edition</title>
    <style>
        /* Основные стили страницы */
        body {
            margin: 0;
            background-color: #1a2421;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: white;
            display: flex;
            justify-content: center;
            padding: 20px;
        }

        /* Кнопки меню */
        .menu-btn {
            background: #2d3436;
            color: white;
            border: 1px solid #444;
            padding: 10px;
            text-align: left;
            cursor: pointer;
            border-radius: 4px;
            transition: 0.3s;
            width: 100%;
        }

        .menu-btn:hover {
            background: #444;
            border-color: #f1c40f;
        }

        /* Поля ввода и выбора */
        input, select {
            background: #333;
            color: white;
            border: 1px solid #555;
            border-radius: 3px;
            box-sizing: border-box;
        }

        .radio-box {
            display: block;
            margin-bottom: 8px;
            cursor: pointer;
            font-size: 14px;
        }

        .radio-box input {
            margin-right: 8px;
        }

        /* Утилиты */
        .hidden {
            display: none !important;
        }
    </style>
</head>
<body>

    <div style="display: flex; width: 100%; max-width: 1100px; gap: 20px;">

        <div id="sidebar" style="width: 200px; display: flex; flex-direction: column; gap: 10px;">
            
            <button class="menu-btn">Об игре</button>
            <button class="menu-btn">Список котов</button>
            <button class="menu-btn">ЛС</button>
            <button class="menu-btn">Чат</button>
            <button class="menu-btn">Новости</button>
            
            <hr style="width: 100%; border: 0.5px solid #444;">

            <div id="game-buttons" class="hidden" style="display: flex; flex-direction: column; gap: 10px;">
                <button class="menu-btn" style="color: #f1c40f;">Игровая</button>
                <button class="menu-btn" style="color: #f1c40f;">Мой кот</button>
                <hr style="width: 100%; border: 0.5px solid #444;">
            </div>

            <div id="auth-buttons" style="display: flex; flex-direction: column; gap: 10px;">
                <button class="menu-btn" style="background: #27ae60;">Регистрация</button>
                <button class="menu-btn">Вход</button>
            </div>
        </div>

        <div style="flex: 1; display: flex; flex-direction: column; gap: 20px;">
            
            <div id="header-art" style="width: 100%; height: 200px; background: #2c3e50; border: 2px solid #3e5871; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 24px; background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('https://via.placeholder.com/900x200'); background-size: cover;">
                [ АРТ ТВОЕЙ ВСЕЛЕННОЙ ]
            </div>

            <div id="main-content" style="min-height: 400px; background: rgba(255,255,255,0.05); border: 1px solid #444; border-radius: 10px; padding: 30px;">
                
                <div id="registration-form">
                    <h2 style="margin-top: 0; color: #f1c40f; text-align: center;">Создание персонажа</h2>
                    
                    <div style="display: flex; gap: 15px; background: rgba(0,0,0,0.2); padding: 15px; border-radius: 10px;">
                        
                        <div style="flex: 1; border-right: 1px solid #444; padding-right: 10px;">
                            <h4 style="margin-bottom: 10px; border-bottom: 1px solid #f1c40f;">1. ВСЕЛЕННАЯ</h4>
                            <label class="radio-box"><input type="radio" name="universe" onclick="showTribes('creators')"> Ткущие Судьбы</label>
                            <label class="radio-box"><input type="radio" name="universe" onclick="showTribes('lake')"> Шепот Глубин</label>
                            <label class="radio-box"><input type="radio" name="universe" onclick="showTribes('steel')"> Хранители Стали</label>
                        </div>

                        <div style="flex: 1; border-right: 1px solid #444; padding-right: 10px;">
                            <h4 style="margin-bottom: 10px; border-bottom: 1px solid #f1c40f;">2. ПЛЕМЯ</h4>
                            <div id="tribe-list" style="font-size: 14px; color: #aaa;">Сначала выберите вселенную...</div>
                        </div>

                        <div style="flex: 1.2;">
                            <h4 style="margin-bottom: 10px; border-bottom: 1px solid #f1c40f;">3. ПЕРСОНАЖ</h4>
                            <input type="text" id="cat-name" placeholder="Имя..." style="width: 100%; padding: 8px; margin-bottom: 10px;">
                            
                            <select id="cat-gender" style="width: 100%; padding: 8px; margin-bottom: 10px;">
                                <option value="male">Кот</option>
                                <option value="female">Кошка</option>
                            </select>

                            <input type="email" id="cat-email" placeholder="Почта..." style="width: 100%; padding: 8px; margin-bottom: 10px;">
                            <input type="password" id="cat-pass" placeholder="Пароль..." style="width: 100%; padding: 8px; margin-bottom: 15px;">
                            
                            <button onclick="finishRegistration()" style="width: 100%; padding: 12px; background: #27ae60; color: white; border: none; border-radius: 20px; cursor: pointer; font-weight: bold; text-transform: uppercase;">Создать</button>
                        </div>
                    </div>
                </div>

                <div id="game-screen" class="hidden" style="text-align: center; padding-top: 50px;">
                    <h2 id="welcome-msg" style="color: #f1c40f;">Добро пожаловать!</h2>
                    <p>Вы успешно создали персонажа. Теперь используйте меню слева для игры.</p>
                </div>

            </div>
        </div>
    </div>

    <script>
        // Данные о племенах
        const tribesData = {
            creators: ["Племя Звездной Пыли", "Клан Туманных Скал"],
            lake: ["Озерный Дозор", "Племя Текучей Воды"],
            steel: ["Банда Промзоны", "Орден Железных Лап"]
        };

        // Показ племен в зависимости от вселенной
        function showTribes(universe) {
            const list = document.getElementById('tribe-list');
            list.innerHTML = "";
            
            tribesData[universe].forEach(tribe => {
                list.innerHTML += `
                    <label class="radio-box">
                        <input type="radio" name="tribe" value="${tribe}"> ${tribe}
                    </label>
                `;
            });
        }

        // Завершение регистрации
        function finishRegistration() {
            const name = document.getElementById('cat-name').value;
            
            if (name.trim() === "") {
                alert("Введите имя вашего кота!");
                return;
            }

            // 1. Скрываем форму регистрации и показываем экран успеха
            document.getElementById('registration-form').classList.add('hidden');
            document.getElementById('game-screen').classList.remove('hidden');
            
            // 2. Обновляем текст приветствия
            document.getElementById('welcome-msg').innerText = "Кот " + name + " готов к приключениям!";

            // 3. Прячем кнопки Входа/Регистрации слева
            document.getElementById('auth-buttons').classList.add('hidden');

            // 4. Показываем игровые кнопки (Игровая, Мой кот)
            document.getElementById('game-buttons').classList.remove('hidden');

            alert("Персонаж успешно создан!");
        }
    </script>
</body>
</html>
