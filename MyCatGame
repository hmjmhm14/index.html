<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CatWar: My Edition</title>
    <style>
        body { margin: 0; background-color: #1a2421; font-family: sans-serif; color: white; display: flex; justify-content: center; padding: 20px; }
        .menu-btn { background: #2d3436; color: white; border: 1px solid #444; padding: 10px; text-align: left; cursor: pointer; border-radius: 4px; width: 100%; margin-bottom: 5px; }
        .menu-btn:hover { border-color: #f1c40f; }
        input, select { background: #333; color: white; border: 1px solid #555; padding: 8px; width: 100%; margin-bottom: 10px; }
        .hidden { display: none !important; }
    </style>
</head>
<body>
    <div style="display: flex; width: 100%; max-width: 1100px; gap: 20px;">
        <div id="sidebar" style="width: 200px;">
            <button class="menu-btn">Об игре</button>
            <button class="menu-btn">Список котов</button>
            <button class="menu-btn">Новости</button>
            <hr style="border: 0.5px solid #444;">
            <div id="game-buttons" class="hidden">
                <button class="menu-btn" style="color: #f1c40f;">Игровая</button>
                <button class="menu-btn" style="color: #f1c40f;">Мой кот</button>
            </div>
            <div id="auth-buttons">
                <button class="menu-btn" style="background: #27ae60;">Регистрация</button>
                <button class="menu-btn">Вход</button>
            </div>
        </div>
        <div style="flex: 1; display: flex; flex-direction: column; gap: 20px;">
            <div id="header-art" style="height: 200px; background: #2c3e50; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 24px;">[ АРТ ВСЕЛЕННОЙ ]</div>
            <div id="main-content" style="background: rgba(255,255,255,0.05); border: 1px solid #444; border-radius: 10px; padding: 30px;">
                <div id="registration-form">
                    <h2 style="text-align: center; color: #f1c40f;">Создание персонажа</h2>
                    <div style="display: flex; gap: 15px;">
                        <div style="flex: 1;">
                            <h4>1. ВСЕЛЕННАЯ</h4>
                            <label><input type="radio" name="u" onclick="showTribes('creators')"> Ткущие Судьбы</label><br>
                            <label><input type="radio" name="u" onclick="showTribes('lake')"> Шепот Глубин</label>
                        </div>
                        <div style="flex: 1;">
                            <h4>2. ПЛЕМЯ</h4>
                            <div id="tribe-list">Выберите вселенную...</div>
                        </div>
                        <div style="flex: 1;">
                            <h4>3. ПЕРСОНАЖ</h4>
                            <input type="text" id="cat-name" placeholder="Имя...">
                            <button onclick="finishRegistration()" style="width: 100%; padding: 10px; background: #27ae60; color: white; border: none; cursor: pointer;">СОЗДАТЬ</button>
                        </div>
                    </div>
                </div>
                <div id="game-screen" class="hidden"><h2>Добро пожаловать!</h2><p>Персонаж создан.</p></div>
            </div>
        </div>
    </div>
    <script>
        const tribesData = { creators: ["Племя Звездной Пыли", "Клан Туманных Скал"], lake: ["Озерный Дозор", "Племя Текучей Воды"] };
        function showTribes(u) {
            const list = document.getElementById('tribe-list');
            list.innerHTML = "";
            tribesData[u].forEach(t => { list.innerHTML += `<label><input type="radio" name="t" value="${t}"> ${t}</label><br>`; });
        }
        function finishRegistration() {
            const n = document.getElementById('cat-name').value;
            if(!n) return alert("Введите имя!");
            document.getElementById('registration-form').classList.add('hidden');
            document.getElementById('game-screen').classList.remove('hidden');
            document.getElementById('auth-buttons').classList.add('hidden');
            document.getElementById('game-buttons').classList.remove('hidden');
        }
    </script>
</body>
</html>
